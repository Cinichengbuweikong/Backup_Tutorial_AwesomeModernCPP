{
  "permissions": {
    "allow": [
      "mcp__web-search-prime__web_search_prime",
      "Bash(g++ * -o /tmp/*)",
      "Bash(g++ * -S -o /tmp/*)",
      "Bash(/tmp/*)",
      "Bash(ls *)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/block-bare-python.sh"
          }
        ]
      }
    ]
  }
}
